# Copy this file to `.env` for local development and replace placeholders.
# Never commit your real `.env` file.

POSTGRES_PASSWORD=change-me-postgres-password
DB_PASSWORD=change-me-postgres-password

JWT_SECRET=change-me-jwt-secret-min-32-characters

APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_EMAIL=admin@sgilib.dev
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

SGILIB_DESKTOP_API_SYNC=true
SGILIB_API_BASE=http://localhost:8080/api/v1
SGILIB_API_USER=admin
SGILIB_API_PASSWORD=change-me-admin-password
